#!/usr/bin/env bash
# Launcher for the Koel FrankenPHP standalone distribution.
#
# Convention-only — all writable state lives under $HOME/.koel/:
#   $HOME/.koel/.env         — environment file
#   $HOME/.koel/storage/     — Laravel storage path
#   $HOME/.koel/storage/app/artifacts/ — transcodes, downloaded podcasts, etc.
#   $HOME/.koel/db.sqlite    — SQLite database
#   $HOME/.koel/php.d/       — runtime PHP-INI overrides
#
# Invocation passes through to FrankenPHP's CLI:
#   ./koel php-server [--listen :8000] [--domain my.koel.example]
#   ./koel php-cli artisan <command>
#
# The script lives next to the `frankenphp` binary and the extracted `koel/`
# application tree; build.sh assembles the three into a distributable bundle.

set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
KOEL_DIR="$HERE/app"
FRANKENPHP="$HERE/frankenphp"
KOEL_HOME="$HOME/.koel"

if [[ ! -x "$FRANKENPHP" ]]; then
	echo "[koel] $FRANKENPHP not found or not executable; this launcher must live next to the bundled frankenphp binary." >&2
	exit 2
fi
if [[ ! -d "$KOEL_DIR" ]]; then
	echo "[koel] $KOEL_DIR not found; this launcher must live next to the bundled app/ tree." >&2
	exit 2
fi

mkdir -p \
	"$KOEL_HOME" \
	"$KOEL_HOME/storage/app/public" \
	"$KOEL_HOME/storage/app/artifacts" \
	"$KOEL_HOME/storage/framework/cache/data" \
	"$KOEL_HOME/storage/framework/sessions" \
	"$KOEL_HOME/storage/framework/views" \
	"$KOEL_HOME/storage/logs" \
	"$KOEL_HOME/storage/search-indexes" \
	"$KOEL_HOME/php.d"

# PHP-INI overrides — koel ships with PDO::MYSQL_ATTR_* constants that PHP 8.5
# (FrankenPHP's bundled PHP) deprecates; without these the deprecation lands
# in the response stream and corrupts JSON. Same set as koel's Caddyfile.example.
cat > "$KOEL_HOME/php.d/koel.ini" <<'EOF'
display_errors=Off
log_errors=On
error_reporting=E_ALL & ~E_DEPRECATED & ~E_STRICT
upload_max_filesize=512M
post_max_size=512M
max_execution_time=300
max_input_time=300
EOF
export PHP_INI_SCAN_DIR="$KOEL_HOME/php.d"

# First-run init — fingerprinted on .env's existence.
if [[ ! -f "$KOEL_HOME/.env" ]]; then
	echo "[koel] first-run init in $KOEL_HOME" >&2
	# Portable sed (works on macOS BSD + GNU): write through a temp file.
	tmpfile="$(mktemp)"
	sed \
		-e 's|^APP_DEBUG=.*|APP_DEBUG=false|' \
		-e 's|^DB_CONNECTION=.*|DB_CONNECTION=sqlite|' \
		-e 's|^DB_HOST=.*|DB_HOST=|' \
		-e 's|^DB_PORT=.*|DB_PORT=|' \
		-e "s|^DB_DATABASE=.*|DB_DATABASE=$KOEL_HOME/db.sqlite|" \
		-e 's|^DB_USERNAME=.*|DB_USERNAME=|' \
		-e 's|^DB_PASSWORD=.*|DB_PASSWORD=|' \
		-e "s|^ARTIFACTS_PATH=.*|ARTIFACTS_PATH=$KOEL_HOME/storage/app/artifacts|" \
		"$KOEL_DIR/.env.example" > "$tmpfile"
	# .env.example may not have ARTIFACTS_PATH defined at all — append if missing.
	if ! grep -q '^ARTIFACTS_PATH=' "$tmpfile"; then
		echo "ARTIFACTS_PATH=$KOEL_HOME/storage/app/artifacts" >> "$tmpfile"
	fi
	mv "$tmpfile" "$KOEL_HOME/.env"
	touch "$KOEL_HOME/db.sqlite"
fi

# Wire the embedded app into the writable state.
ln -snf "$KOEL_HOME/.env" "$KOEL_DIR/.env"
if [[ ! -L "$KOEL_DIR/public/storage" ]]; then
	rm -rf "$KOEL_DIR/public/storage"
fi
ln -snf "$KOEL_HOME/storage/app/public" "$KOEL_DIR/public/storage"
export LARAVEL_STORAGE_PATH="$KOEL_HOME/storage"

cd "$KOEL_DIR"

install_scheduler_cron() {
	case "$(uname -s)" in
		Linux|Darwin) ;;
		*) return 0 ;;
	esac

	if ! command -v crontab >/dev/null 2>&1; then
		echo "[koel] crontab not found; scheduled tasks won't run until you set up scheduling manually." >&2
		return 0
	fi

	# Marker pairs the launcher's absolute path with the artisan invocation so
	# different bundles (or relocations) don't collide and re-installs are idempotent.
	local marker="$HERE/koel php-cli artisan schedule:run"
	local line="* * * * * $marker >> $KOEL_HOME/storage/logs/scheduler.log 2>&1"

	if crontab -l 2>/dev/null | grep -qF "$marker"; then
		return 0
	fi

	if ( crontab -l 2>/dev/null; echo "$line" ) | crontab - 2>/dev/null; then
		echo "[koel] installed crontab entry for scheduled tasks (edit with: crontab -e)" >&2
	else
		echo "[koel] failed to install crontab entry; scheduled tasks won't run. To install manually, add this line to your crontab:" >&2
		echo "       $line" >&2
	fi
}

# Post-wiring first-run init that needs PHP. Delegates to koel:init — the same
# command Pre-Compiled Archive users and koel/koel's release workflow run.
# Handles key:generate, migrations, default admin seed, storage:link, etc.
# `--no-scheduler` suppresses koel:init's own crontab install (it hardcodes
# `php`, won't work for the bundle); we install our own corrected entry below.
if [[ ! -f "$KOEL_HOME/.initialized" ]]; then
	"$FRANKENPHP" php-cli artisan koel:init --no-assets --no-scheduler --no-interaction >&2
	install_scheduler_cron
	touch "$KOEL_HOME/.initialized"
fi

if [[ $# -lt 1 ]]; then
	echo "Usage: $0 <php-server|php-cli|run|version|…> [args…]" >&2
	exit 2
fi
SUBCMD="$1"; shift

# `php-server` defaults its document root to the cwd; koel's index.php lives
# under public/. Inject --root public/ unless the user already passed one.
if [[ "$SUBCMD" == "php-server" ]]; then
	HAS_ROOT=0
	for arg in "$@"; do
		case "$arg" in
			--root|--root=*) HAS_ROOT=1 ;;
		esac
	done
	if [[ $HAS_ROOT -eq 0 ]]; then
		set -- "--root" "public/" "$@"
	fi
fi

exec "$FRANKENPHP" "$SUBCMD" "$@"
